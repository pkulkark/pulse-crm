{
  "name": "workspace",
  "$schema": "./node_modules/nx/schemas/project-schema.json",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 scripts/verify_phase0.py --mode lint"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 -m unittest discover -s tests -p 'test_*.py'"
      }
    }
  }
}
