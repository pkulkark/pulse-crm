{
  "name": "frontend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/frontend/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run build --workspace @pulsecrm/frontend"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint --workspace @pulsecrm/frontend"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run dev --workspace @pulsecrm/frontend -- --host 0.0.0.0 --port 3000"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run test --workspace @pulsecrm/frontend"
      }
    }
  }
}
