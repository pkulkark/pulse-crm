{
  "name": "frontend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/frontend/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run build --workspace @samplecrm/frontend"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint --workspace @samplecrm/frontend"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run dev --workspace @samplecrm/frontend -- --host 0.0.0.0 --port 3000"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 scripts/verify_phase0.py --mode frontend"
      }
    }
  }
}
