{
  "name": "identity-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/identity_service",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 scripts/verify_phase0.py --mode django-service --service identity_service"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 scripts/verify_phase0.py --mode django-service --service identity_service"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/identity_service && python3 manage.py runserver 0.0.0.0:8000"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 scripts/verify_phase0.py --mode django-test --service identity_service"
      }
    }
  }
}
